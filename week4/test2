#include <stdio.h>
#include <mpi.h>
/* initialise mpi and get rank + size of communicator */
void init_mpi(int argc, char **argv, int *rank, int *size)
{
    MPI_Init(&argc, &argv);// start mpi environment
    MPI_Comm_rank(MPI_COMM_WORLD, rank);// get this process' rank
    MPI_Comm_size(MPI_COMM_WORLD, size); // get total number of processes
}
/* worker processes send data to root */
void worker_send(int rank, int tag)
{
    int send_message = rank * 10; // simple message based on rank
    int dest = 0;// all workers send to rank 0

// send message to root process
    MPI_Send(&send_message, 1, MPI_INT, dest, tag, MPI_COMM_WORLD);

// print confirmation
    printf("hello, i am rank %d. sent %d to rank %d\n",
           rank, send_message, dest);
}
/* root process (rank 0) receives messages from all other ranks */
void root_receive(int size, int tag)
{
    int recv_message;// buffer for received data
    MPI_Status status;// stores info about received message
 // loop over all worker ranks (1 to size-1)
    for (int source = 1; source < size; source++)
    {
// receive message from a specific source (blocking call)
        MPI_Recv(&recv_message, 1, MPI_INT, source, tag,
                 MPI_COMM_WORLD, &status);
 // print received message
        printf("hello, i am rank 0 of %d. received %d from rank %d\n",
               size, recv_message, source);
    }
}

/* main function controls overall mpi program flow */1~
int main(int argc, char **argv)
{
    int rank, size;
    int tag = 0;// message tag used for matching sends and receives

// initialise mpi and get rank/size
    init_mpi(argc, argv, &rank, &size);

// ensure at least 2 processes are running
    if (size > 1)
    {
// root process receives
        if (rank == 0)
	{
            root_receive(size, tag);
        }
// worker processes send
	else
	{
            worker_send(rank, tag);
	}
 
    }
    else
    {
// safety check for incorrect execution
        printf("unable to communicate with less than 2 processes. size = %d\n", size);
    }
// finalise mpi environment
    MPI_Finalize();
    return 0;
}
